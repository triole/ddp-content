[{
    "srcDir": ".",
    "destDir": "/tmp/.on-save",
    "files": "sh/*",
    "command": "coda -t '${srcFile}'",
    "showOutput": false,
    "showError": false
},
{
    "srcDir": ".",
    "destDir": "/tmp/.on-save",
    "files": "content/*",
    "command": "markdownfmt -w '${srcFile}'",
    "showOutput": false,
    "showError": false
}]
